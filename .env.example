# ============================================================
# PostgreSQL 连接串（[阶段 1] 2026-06-29 引入）
# 复制本文件为 .env，填入真值；.env 已在 .gitignore 中
# ============================================================

# 本地 docker（推荐开发用）：
#   docker run -d --name o2o-pg -p 5432:5432 \
#     -e POSTGRES_USER=o2o -e POSTGRES_PASSWORD=o2o -e POSTGRES_DB=o2o \
#     postgres:16-alpine
#
# Railway / Neon / Supabase 都会给一个 postgresql:// 连接串，直接粘
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public"

# [v0.6.0] iron-session 密钥（修 ADR-013 A2 P0 风险）
# 必须 32+ 字符随机串。生产用 `openssl rand -hex 32` 生成。
# ⚠️ 绝对不要 commit 真值
SESSION_SECRET="CHANGE_ME_TO_RANDOM_32_CHARS_MIN_LENGTH_xxxxxxxxxxxxx"

# 可选 — Prisma migrate dev 用的影子 DB（避免污染主库）
# 托管服务一般会自动建一个 schema；本地手动建同名 DB 即可
# SHADOW_DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME_shadow?schema=public"
