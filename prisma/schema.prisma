// Prisma schema — O2O MVP 第一版
// 选 SQLite 是本地开发零配置、文件即数据库；将来迁 Postgres 主要改 datasource 即可。
//
// [阶段 1 — 2026-06-29] 已迁到 PostgreSQL。SQLite 文件 prisma/dev.db 留作回滚兜底。
//   切回 SQLite: 把 provider 改回 "sqlite"、url 改回 "file:./dev.db"、删 migrations/ 即可。

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// 服务类目（如：家政、家电清洗、维修、母婴、应急）
// ============================================================
model ServiceCategory {
  id          String   @id @default(cuid())
  name        String   @unique
  // 业务编码（如 "CLEAN"、"REPAIR"）— 比 cuid 更稳定，便于 API / 表单传输
  // 大小写策略：应用层强制大写（src/lib/codes.ts 的 normalizeCode）；
  // SQLite 不支持 @db.Collate，应用层是唯一防线。
  categoryCode String  @unique
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())

  skus ServiceSku[]
}

// ============================================================
// 服务 SKU（具体的服务项目）
// ============================================================
model ServiceSku {
  id              String   @id @default(cuid())
  // 业务编码（如 "CLEAN-DAILY-2H"）— 用户友好，比 cuid 短
  // 大小写策略：应用层强制大写（src/lib/codes.ts 的 normalizeCode）；
  // SQLite 不支持 @db.Collate，应用层是唯一防线。
  skuCode         String   @unique
  name            String
  categoryId      String
  category        ServiceCategory @relation(fields: [categoryId], references: [id])
  basePrice       Int                       // 单位：分
  durationMinutes Int
  requiredSkills  String   @default("[]")
  enabled         Boolean  @default(true)
  createdAt       DateTime @default(now())

  orders Order[]

  @@index([categoryId])
}

// ============================================================
// 师傅 / 服务者
// skills 是 JSON 字符串：["保洁", "家电清洗"]
// ============================================================
model Master {
  id            String   @id @default(cuid())
  name          String
  // [P1-2 修] phone 加 @unique — 防止并发/重复提交时绑错师傅
  // findFirst({where:{phone}}) 改为 findUnique — 简化 + 强制约束
  // 注意：MOCK 演示用 "138****1234" 占位不满足 11 位 1 开头，但 unique 约束只要求值唯一（不同 phone 字符串不冲突）
  phone         String   @unique
  skills        String                       // JSON 字符串
  rating        Float    @default(5.0)
  completedJobs Int      @default(0)
  status        String   @default("available") // available | busy | offline
  // 服务区域 — MVP 阶段存为自由文本（"上海" / "北京, 上海"）
  serviceArea   String   @default("")
  // [任务 2] 师傅必须归属一个商家 — 平台合作模式必填
  // # MVP: 必填；演示期不允许师傅独立运营
  merchantId    String
  merchant      Merchant @relation(fields: [merchantId], references: [id])
  // [任务 4] 入驻来源：admin_created（后台建）/ invite_code（/worker/join 入驻）
  // # MVP: 必填；演示期不允许"未指定来源"
  joinSource    String   @default("admin_created") // admin_created | invite_code
  createdAt     DateTime @default(now())

  orders Order[]
  // 反向关系：worker 角色 User 通过 workerId 绑本表
  user   User?
  // [任务 6] 结算预览（1 对多）
  settlementPreviews SettlementPreview[]
  // [任务 17] 师傅维度结算汇总（1 对多）
  workerSettlements  WorkerSettlement[]

  // [任务 T2-1] 师傅提现申请（1 对多 — 同一师傅多次申请）
  workerWithdrawRequests WorkerWithdrawRequest[]

  @@index([status])
  @@index([merchantId])
}

// ============================================================
// 账号体系（[账号阶段] 2026-06-29 引入）
// 四种角色：admin / worker / customer / merchant
// - admin    : 后台管理员（workerId/merchantId 都 null）
// - worker   : 师傅账号（workerId 绑 Master.id）
// - customer : 用户（按 phone 查订单）
// - merchant : 商家账号（merchantId 绑 Merchant.id）— [任务 18] 商家端后台
// # [v0.3.0] 密码 bcrypt 哈希（修 ADR-013 A1 P0 风险）— rounds=10
// # 旧版注释「MVP 明文」是 v0.2.x 历史遗留，已不再准确
// ============================================================
model User {
  id        String   @id @default(cuid())
  name      String   @unique               // 登录账号（admin / worker1 / customer1 / merchant1）
  phone     String?                       // customer/worker 绑手机号；admin/merchant 可空
  password  String                        // bcrypt(rounds=10) 哈希，验证用 bcrypt.compare
  role      String                        // admin | worker | customer | merchant
  workerId  String?   @unique             // role=worker 时绑 Master.id
  // [任务 18] 商家账号绑定 — merchant 角色必填
  // merchantId 来源：seed 创建时直接写（演示期）；上线后由 admin 后台生成
  // # MVP: 数据库层不强制 role+merchantId 一致（演示期灵活）；requireMerchant() 在业务层校验
  merchantId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  worker    Master?  @relation(fields: [workerId], references: [id])
  // [任务 18] merchant 角色反向关系
  merchant  Merchant? @relation(fields: [merchantId], references: [id], onDelete: SetNull)

  @@index([role])
  @@index([phone])
  @@index([merchantId])
}

// ============================================================
// 订单
// ============================================================
model Order {
  id              String   @id                 // 业务订单号
  customerName    String
  customerPhone   String   @default("")        // 下单时填的手机号
  serviceSkuId    String?
  serviceSku      ServiceSku? @relation(fields: [serviceSkuId], references: [id])
  serviceName     String                       // 冗余快照
  masterId        String?
  master          Master? @relation(fields: [masterId], references: [id])
  masterName      String?                      // 冗余快照
  // [任务 3] 4 级地址字段 — 派单匹配必用（精确 4 级 = PlatformArea）
  // 旧 address 字段保留作为"展示冗余"（拼接 4 级 + detail），不参与匹配
  province        String   @default("")
  city            String   @default("")
  district        String   @default("")
  street          String   @default("")
  addressDetail   String   @default("")
  // 旧 address 字段：保留 = "省/市/区县/街道 addressDetail" 拼接；新订单不写，靠读取时拼
  address         String
  scheduledAt     DateTime
  amount          Int                          // 单位：分
  status          String   @default("pending") // pending | assigned | in_service | completed | cancelled
  // [支付] 任务 X + 任务 19: payStatus 独立于 status — 模拟支付（演示期不接真实支付）
  // unpaid    = 下单后未付, status=pending + payStatus=unpaid  = 待支付
  // paid      = 模拟支付成功, status=pending + payStatus=paid    = 待派单
  // refunding = 退款处理中, status=cancelled + payStatus=refunding （任务 19 加中间态）
  // refunded  = 已退款,     status=cancelled + payStatus=refunded  （任务 19 终态）
  // 派单校验: status=pending AND payStatus=paid
  // 取消已支付订单时：事务内两步 paid → refunding → refunded（同步释放师傅）
  // refunding 状态 assignOrder 自动拒绝（payStatus !== "paid"）
  payStatus       String   @default("unpaid")  // unpaid | paid | refunding | refunded
  paidAt          DateTime?                    // 支付成功时间
  // 用户下单时填的备注（可选）— 加于 2026-06 师傅端/用户端 MVP
  remark          String?
  // [v0.7.6] 业务扩展：内部备注（后台）和师傅完成说明
  // - remark = 用户下单备注（v0.3.0 已有）
  // - internalRemark = 后台调度备注（admin 写，user/worker 看）
  // - serviceSummary = 师傅完成订单时填的服务说明（admin/user/worker 看）
  internalRemark  String?
  serviceSummary  String?
  // [v0.7.9] 取消订单字段
  // - cancelReason = 取消原因（in_service 必填，其他选填；3 端都展示）
  // - canceledAt = 取消时间（status=cancelled 时有值）
  cancelReason   String?
  canceledAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // [任务 6] 结算预览（1 对 1）
  settlementPreview SettlementPreview?

  @@index([status])
  @@index([scheduledAt])
}

// ============================================================
// 派单规则
// ruleJson 是结构化 JSON，dispatch.ts 解析它来匹配师傅。
//
// 约定的 schema（UI 字段 → ruleJson 映射）：
//   {
//     "match": {
//       "skuId": "<ServiceSku.id>",       // 可选 — 精确 SKU 匹配
//       "categoryId": "<ServiceCategory.id>"  // 可选 — 类目兜底匹配
//     },
//     "requiredSkills": ["空调维修"]
//   }
//
// UI 层用 skuCode / categoryCode 业务编码，repo 层负责反查 ID 写入 ruleJson。
// 同一订单先按 skuId 找；找不到再按 categoryId 兜底；都没有就不进派单。
// ============================================================
model DispatchRule {
  id        String   @id @default(cuid())
  name      String
  priority  Int      @default(0)
  enabled   Boolean  @default(true)
  ruleJson  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([enabled, priority])
}

// ============================================================
// 平台合作区域（任务 1：服务商 / 商家平台模式底座）
//
// 含义：平台确认开放合作的四级服务区域。
// 注意：本阶段只建平台区域主数据，不做 MerchantArea，不让商家绑定区域。
// ============================================================
model PlatformArea {
  id        String   @id @default(cuid())
  province  String
  city      String
  district  String
  street    String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // [任务 2] 反向关系：被哪些商家绑定
  merchantAreas MerchantArea[]

  @@unique([province, city, district, street])
  @@index([enabled])
}

// ============================================================
// 服务商 / 商家基础资料（任务 1）
//
// 本阶段 Merchant 只是商家基础资料，不做服务区域绑定、不绑定师傅。
// ============================================================
model Merchant {
  id            String   @id @default(cuid())
  name          String
  contactName   String
  phone         String
  status        String   @default("active") // active | inactive
  // [任务 4] 商家邀请码 — 师傅通过 /worker/join 入驻绑定
  // 创建时自动生成（8 字符 base36）；seed 也填
  inviteCode        String   @unique
  inviteCodeEnabled Boolean  @default(true)
  province      String
  city          String
  district      String
  street        String
  addressDetail String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // [任务 2] 商家绑定的区域（多对多）
  merchantAreas MerchantArea[]

  // [任务 2] 商家拥有的师傅（1 对多）
  masters       Master[]

  // [任务 5] 商家分成策略（1 对多）
  commissionStrategies CommissionStrategy[]

  // [任务 6] 结算预览（1 对多）
  settlementPreviews SettlementPreview[]

  // [任务 7] 商家结算汇总（1 对多 — 一个商家跨多个月）
  merchantSettlements MerchantSettlement[]

  // [任务 12] 线下打款记录（1 对多 — 同一商家多次打款）
  payoutRecords PayoutRecord[]

  // [任务 13] 提现申请（1 对多 — 同一商家多次申请）
  withdrawRequests WithdrawRequest[]

  // [任务 14] 财务流水（1 对多 — 商家维度账）
  financeLedgers FinanceLedger[]

  // [任务 18] 商家后台账号（1 对多 — 一个商家可有多个 merchant 账号登入）
  users User[]

  @@index([status])
  @@index([province, city, district, street])
}

// ============================================================
// 商家合作区域绑定（[任务 2] 商家绑定平台合作区域）
//
// 设计要点：
// - merchantId + platformAreaId 联合唯一（防重复绑定）
// - enabled=false 时该区域不参与派单（任务 3 实施）
// - 一个商家可绑定多个 PlatformArea
// - 一个 PlatformArea 可被多个商家绑定
// - PlatformArea 必须是 enabled=true 才能被绑定
// ============================================================
model MerchantArea {
  id            String   @id @default(cuid())
  merchantId    String
  platformAreaId String
  enabled       Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now())

  merchant      Merchant     @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  platformArea  PlatformArea @relation(fields: [platformAreaId], references: [id], onDelete: Restrict)

  @@unique([merchantId, platformAreaId])
  @@index([merchantId])
  @@index([platformAreaId])
}

// ============================================================
// [任务 5] 分成策略（CommissionStrategy）
//
// - 归属 Merchant（多对一）
// - strategyType=percentage：platformRate + merchantRate + workerRate 必须 = 1，每个 0-1
// - strategyType=fixed：3 个 fixed 金额都必须 >= 0
// - enabled 默认 true
// - 一个商家可有多条策略
// - 不做支付/提现/结算，只做配置
// ============================================================
model CommissionStrategy {
  id        String   @id @default(cuid())
  merchantId String
  merchant   Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  name       String   // 策略名（如 "默认策略" "保洁专项"）
  strategyType String  // percentage | fixed
  // percentage 模式
  platformRate  Float  @default(0)
  merchantRate  Float  @default(0)
  workerRate    Float  @default(0)
  // fixed 模式（单位：分）
  fixedPlatformAmount Int @default(0)
  fixedMerchantAmount Int @default(0)
  fixedWorkerAmount   Int @default(0)
  enabled Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // [任务 6] 反向关系：结算预览可追溯用的策略
  settlementPreviews SettlementPreview[]

  @@index([merchantId])
  @@index([enabled])
}

// ============================================================
// [任务 6] 结算预览（SettlementPreview）
//
// - 每张完成订单一条预览
// - orderId @unique（防重复生成）
// - 三方分成金额（单位：分）— 由该订单对应商家的 CommissionStrategy 算
// - 不做提现/打款/真实结算
// ============================================================
model SettlementPreview {
  id        String   @id @default(cuid())
  orderId   String   @unique
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  merchantId String
  merchant   Merchant @relation(fields: [merchantId], references: [id])
  masterId  String
  master    Master   @relation(fields: [masterId], references: [id])
  // 策略快照 ID — 用来追溯用的策略（不强制 FK；可空表示无策略 fallback）
  strategyId String?
  strategy   CommissionStrategy? @relation(fields: [strategyId], references: [id], onDelete: SetNull)
  // 订单金额（快照，不变）
  orderAmount Int
  // 三方分成（单位：分）
  platformAmount Int
  merchantAmount Int
  workerAmount   Int
  // 状态：generated / archived / failed
  status    String   @default("generated")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([merchantId])
  @@index([status])
}

// ============================================================
// [任务 7] 商家结算汇总（MerchantSettlement）
//
// - 按 merchantId + period（year-month，例 "2026-06"）聚合 SettlementPreview
// - totalOrderCount：completed 订单数
// - totalAmount：订单总金额（单位：分）
// - platformFee / merchantIncome / workerIncome：三方分成（单位：分）
// - (merchantId, period) unique — 同一商家同月只 1 条
// - 不做打款/提现
// ============================================================
model MerchantSettlement {
  id        String   @id @default(cuid())
  merchantId String
  merchant   Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  // 期间（year-month，例 "2026-06"）
  period    String
  // 订单数（completed 订单数）
  totalOrderCount Int @default(0)
  // 订单总金额（分）
  totalAmount Int @default(0)
  // 三方分成（分）
  platformFee      Int @default(0)
  merchantIncome   Int @default(0)
  workerIncome     Int @default(0)
  // [任务 9+10] 状态机：pending / confirmed / archived
  // - pending：刚生成，待 admin 确认
  // - confirmed：已确认（admin 主动确认）
  // - archived：周期已关闭，只读不可再改
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // [任务 12] 反向关系：线下打款记录（1 对多）
  payoutRecords PayoutRecord[]

  @@unique([merchantId, period])
  @@index([period])
  @@index([status])
}

// ============================================================
// [任务 17] 师傅维度结算汇总（WorkerSettlement）
//
// 设计要点：
// - workerId: FK Master（Cascade）— 删师傅时自动清汇总
// - period: "YYYY-MM"（与 MerchantSettlement 口径一致）
// - orderCount: 该 (worker, period) 下 completed 订单数
// - totalAmount: 该 (worker, period) 下 completed 订单总金额（分）
// - workerIncome: 师傅实收（分，来自 SettlementPreview.workerAmount 之和）
//
// 与 MerchantSettlement 的差异：
// - 无 status 字段（无状态机，仅展示用）
// - 无 platformFee / merchantIncome（worker 视角不关心）
// - 无 payoutRecords 关系（不走打款）
//
// 数据源：SettlementPreview（commission strategy 拆分后）
// 生成时机：admin 点 "生成汇总" 按钮（手动触发）
// 更新策略：upsert 同 (worker, period) 重新聚合
// 快照语义：masterId 变更后历史 settlement 保留（与 MerchantSettlement 一致）
// ============================================================
model WorkerSettlement {
  id           String   @id @default(cuid())
  workerId     String
  worker       Master   @relation(fields: [workerId], references: [id], onDelete: Cascade)
  period       String   // "YYYY-MM"
  orderCount   Int      @default(0)
  totalAmount  Int      @default(0) // 订单总金额（分）
  workerIncome Int      @default(0) // 师傅实收（分）
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([workerId, period])
  @@index([period])
  @@index([workerId])
}

// ============================================================
// [任务 12] 线下打款记录（PayoutRecord）
//
// 设计要点：
// - withdrawRequestId = MerchantSettlement.id (FK, onDelete Cascade)
//   字面含义"打款请求 ID" — 业务上"线下打款"指对已审核通过的结算汇总结算
// - amount: 单位 分
// - paidAt: 必填（线下打款必有时间）
// - proofUrl: optional；若填则必须 http(s):// 开头
// - operator: 操作人 User.name 字符串（冗余，删 user 不影响记录）
// - 同一 settlement 允许多条 PayoutRecord（分批打款）；Σ(amount) ≤ settlement.merchantIncome
// - 只录入不接支付通道
// ============================================================
model PayoutRecord {
  id        String   @id @default(cuid())
  // FK MerchantSettlement.id（Cascade）
  withdrawRequestId String
  settlement        MerchantSettlement @relation(fields: [withdrawRequestId], references: [id], onDelete: Cascade)
  // 反范式存 merchantId：方便 /payout-records 列表筛选
  merchantId String
  merchant   Merchant @relation(fields: [merchantId], references: [id])
  // 打款金额（单位：分）
  amount Int
  // 打款时间（必填）
  paidAt DateTime
  // 打款凭证 URL（optional；填了必须 http(s):// 开头）
  proofUrl String?
  // 操作人（admin User.name 冗余）
  operator String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([withdrawRequestId])
  @@index([merchantId])
  @@index([paidAt])
}

// ============================================================
// [任务 T2-1] 师傅提现申请（WorkerWithdrawRequest）
//
// 设计要点（与 WithdrawRequest 镜像）：
// - workerId 必填（FK Master；Cascade）
// - amount 单位：分（与 WorkerSettlement 一致）
// - status：pending / approved / rejected
//   - pending → approved（admin 通过）
//   - pending → rejected（admin 拒绝）— 必填 rejectReason
// - remark：师傅自己填的用途说明（可选）
// - reviewerName：冗余 User.name（删 user 不影响记录）
// - 可提现余额算法：Σ(WorkerSettlement.workerIncome)
//                    − Σ(approved + pending WorkerWithdrawRequest.amount)
// - DB partial unique: (workerId) WHERE status='pending'
//   — 防同师傅并发创建 2 条 pending（与 WithdrawRequest 同样的 P0 风险）
// - 师傅自己申请；admin 审核；不写 FinanceLedger（无 payout 流程）
// - 只做申请和审核；不做真实打款
// ============================================================
model WorkerWithdrawRequest {
  id        String   @id @default(cuid())
  workerId  String
  worker    Master   @relation(fields: [workerId], references: [id], onDelete: Cascade)
  // 申请金额（分）
  amount    Int
  // 状态机
  status    String   @default("pending") // pending | approved | rejected
  // 师傅填的用途说明（optional）
  remark    String?
  // 审核人（User.name 字符串冗余）
  reviewerName String?
  // 审核时间（status ∈ approved/rejected 时有值）
  reviewedAt   DateTime?
  // 拒绝原因（status=rejected 必填）
  rejectReason String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workerId])
  @@index([status])
  @@index([createdAt])
}
//
// 设计要点：
// - merchantId 必填（FK Merchant；状态 active 才允许申请）
// - amount 单位：分（与 MerchantSettlement 一致）
// - status：pending / approved / rejected
//   - pending → approved（admin 通过）— 实际打款仍走 /merchant-settlements 录 PayoutRecord
//   - pending → rejected（admin 拒绝）— 必填 rejectReason
// - remark：merchant 端填的用途说明（可选；admin 代填允许）
// - reviewerName：冗余 User.name（删 user 不影响记录）
// - 可提现余额算法：Σ(confirmed + archived MerchantSettlement.merchantIncome)
//                    − Σ(PayoutRecord.amount)
//                    − Σ(approved + pending WithdrawRequest.amount)
// - 只做申请和审核；不做真实打款
// ============================================================
model WithdrawRequest {
  id        String   @id @default(cuid())
  merchantId String
  merchant   Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  // 申请金额（分）
  amount Int
  // 状态机
  status    String   @default("pending") // pending | approved | rejected
  // merchant 填的用途说明（optional）
  remark    String?
  // 审核人（User.name 字符串冗余）
  reviewerName String?
  // 审核时间（status ∈ approved/rejected 时有值）
  reviewedAt   DateTime?
  // 拒绝原因（status=rejected 必填）
  rejectReason String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([merchantId])
  @@index([status])
  @@index([createdAt])
}

// ============================================================
// [任务 14] 财务流水（FinanceLedger）
//
// 设计要点：
// - 商家维度账（merchantId 必填）
// - type: order_commission（订单分成）/ withdraw（提现）/ payout（打款）
// - direction: 'out'（平台减项）— MVP 简化，所有流水都是 out
// - sourceId: 关联业务对象的 id（MerchantSettlement.id / WithdrawRequest.id / PayoutRecord.id）
// - 幂等约束：@@unique([type, sourceId]) — 同 type 同 sourceId 只能记 1 笔
// - 触发：
//   - order_commission: settlement.confirmed 时记录（按 settlement.merchantIncome）
//   - withdraw: WithdrawRequest.approved 时记录（按 withdraw.amount）
//   - payout: PayoutRecord.create 时记录（按 payout.amount）
// - amount: Decimal(12,2) — PG 原生支持；SQLite 演示期不写
// - 只记账，不接银行
// ============================================================
model FinanceLedger {
  id        String   @id @default(cuid())
  merchantId String
  merchant   Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  // 类型
  type      String   // order_commission | withdraw | payout
  // 方向 — MVP 全部 'out'
  direction String   @default("out") // out
  // 关联业务对象 id（settlement / withdrawRequest / payoutRecord）
  sourceId  String
  // 关联订单 id（仅 order_commission 才有；其他 NULL）
  orderId   String?
  // 金额（Decimal(12,2) — 元；PG 原生）
  amount    Decimal  @db.Decimal(12, 2)
  // 备注
  remark    String?
  createdAt DateTime @default(now())

  @@unique([type, sourceId])
  @@index([merchantId])
  @@index([type])
  @@index([createdAt])
}

// ============================================================
// 操作日志（[v0.4.0] 2026-06-29 引入）
// 用于后台 Dashboard「最近动态」展示 + 业务追溯。
//
// 设计要点：
// - actor 可空（system 角色，如定时任务、seed 自动行为）
// - targetType / targetId 联动：用于将来按对象查日志
// - metadata 是 String（JSON 字符串）— 跨方言兼容
// - 写入失败不抛错（工具函数 try/catch）— 不能影响主业务
//
// # MVP: 仅记录核心动作；不做复杂审计、不做搜索、不做导出、不做删除
// ============================================================
model ActivityLog {
  id         String   @id @default(cuid())
  actorId    String?                  // 操作人 User.id（可空 = system）
  actorName  String                   // 冗余：避免 User 删除后日志失名
  actorRole  String                   // admin | worker | customer | system
  action     String                   // 动作类型：order_created / order_assigned / ...
  targetType String                   // 对象类型：order / master / serviceSku / dispatchRule / withdrawRequest / ...
  targetId   String                   // 对象 id
  message    String                   // 人类可读文案
  metadata   String   @default("{}")  // JSON 字符串（可空）
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([targetType, targetId])
  @@index([actorId])
}
